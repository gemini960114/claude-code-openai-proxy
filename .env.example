# 請複製此檔案並命名為 .env，並填入你的真實 API Key
# 警告：請勿將包含真實金鑰的 .env 檔案上傳到 GitHub！

# Inner-Medusa API Key
INNER_MEDUSA_API_KEY="sk-你的-inner-medusa-key"

# Portal API Key
PORTAL_API_KEY="sk-你的-portal-key"

# (選填) 通用後端設定（直接執行 uvicorn 時可使用）
# BACKEND_API_KEY="sk-你的-api-key"
# BACKEND_CHAT_URL="https://portal.genai.nchc.org.tw/api/v1/chat/completions"

# (選填) 自訂模型設定檔路徑，預設使用專案目錄下的 models.json
# MODEL_CONFIG_PATH="models.json"
